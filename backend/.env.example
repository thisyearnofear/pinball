# Server configuration
PORT=8080

# Score signing configuration
SCORE_SIGNER_PK=0xYOUR_PRIVATE_KEY
# Optional (for ops visibility)
SCORE_SIGNER_ADDR=0xYOUR_PUBLIC_ADDRESS

# Must match the chain ID where the tournament contract is deployed
CHAIN_ID=0

# Optional: score signing prefix (must match the contract)
SCORE_PREFIX=PINBALL_SCORE:v2

# RPC used by the backend when it needs to broadcast transactions (e.g. Sponsored Missions payouts)
MEZO_RPC_URL=https://rpc.test.mezo.org

# Optional differentiator: Sponsored Missions contract address (MissionPool)
MISSION_POOL_ADDRESS=

# Optional: minimum score required to trigger a mission award (hackathon-simple rule)
MISSION_SCORE_THRESHOLD=250000

# Optional: require multiball flag in metadata to award mission (enables "Jackpot Multiball")
MISSION_REQUIRE_MULTIBALL=false

# CORS configuration (comma-separated origins)
ALLOWED_ORIGINS=https://your-netlify-site.netlify.app,https://your-domain.tld

# Global rate limit (requests per minute, all endpoints)
RATE_LIMIT=120

# Score submission validation constraints
# Maximum allowed score (prevents obviously bogus submissions)
MAX_SCORE=10000000

# Maximum player name length in characters
PLAYER_NAME_MAX_LENGTH=64

# Maximum metadata JSON size in bytes
MAX_METADATA_LENGTH=10000

# Per-address rate limiting for score signatures
# Maximum signature requests allowed per player
SCORE_SIGNATURE_RATE_LIMIT_MAX=3

# Time window for per-address rate limiting (milliseconds)
# Default: 5 minutes (300000 ms)
SCORE_SIGNATURE_RATE_LIMIT_WINDOW=300000
