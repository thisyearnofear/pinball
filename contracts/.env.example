## Contracts deploy configuration (Hardhat)
##
## IMPORTANT: never commit real keys. Use a funded EOA for deploy/admin ops.

# EOA private key used by Hardhat for deploys
PRIVATE_KEY=

# Backend score signer (EOA) that the contract will accept signatures from
SCORE_SIGNER_ADDR=

# MUSD token address on the target chain
# Mezo Testnet MUSD: 0x118917a40FAF1CD7a13dB0Ef56C86De7973Ac503
MUSD_ADDRESS=

# Optional: entry fee in token base units (18 decimals).
# Example: 1000000000000000000 = 1.0 MUSD
ENTRY_FEE=

# Optional overrides for RPCs / chain IDs (defaults match Mezo docs)
MEZO_TESTNET_RPC_URL=https://rpc.test.mezo.org
MEZO_TESTNET_CHAIN_ID=31611

# For mainnet we default to Validation Cloud public endpoint
MEZO_MAINNET_RPC_URL=https://mainnet.mezo.public.validationcloud.io/
MEZO_MAINNET_CHAIN_ID=31612

