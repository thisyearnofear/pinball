{
    "extends": "./tsconfig.app.json",
    "include": [ "src/**/*.ts", "src/**/*.tsx" ],
    "exclude": [ "src/components/**", "tests/**", "apps/**", "backend/**", "contracts/**", "dist/**", "node_modules/**" ],
    "compilerOptions": {
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2021",
        "lib": ["ES2021", "DOM"]
    }
}
