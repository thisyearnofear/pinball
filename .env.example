# Frontend env for Vite
VITE_CHAIN_ID=0

# Public RPC for reliable reads (do not rely on wallet provider RPC for reads)
VITE_RPC_URL_PUBLIC=

# Contracts
VITE_TOURNAMENT_MANAGER_ADDRESS=

# Mezo (future-proof config; may be unused until MUSD integration lands)
VITE_MUSD_ADDRESS=

# Sponsored Missions (optional differentiator)
VITE_MISSION_POOL_ADDRESS=
VITE_ACTIVE_MISSION_ID=

# Backend
VITE_BACKEND_URL=http://localhost:8080

# Optional: score signing protocol
VITE_SCORE_PREFIX=PINBALL_SCORE:v2

# Optional: metadata for wallet_addEthereumChain UX
VITE_CHAIN_NAME=
VITE_BLOCK_EXPLORER_URL=
VITE_NATIVE_CURRENCY_NAME=
VITE_NATIVE_CURRENCY_SYMBOL=
VITE_NATIVE_CURRENCY_DECIMALS=
